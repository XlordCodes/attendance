# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Timezone Configuration
# Office timezone for all attendance calculations and display
# Use IANA timezone format (e.g., Asia/Kolkata, America/New_York, Europe/London)
VITE_OFFICE_TIMEZONE=Asia/Kolkata

# Security Configuration - IP Whitelisting & Geofencing
VITE_OFFICE_IP_ADDRESS=192.168.1.1
VITE_OFFICE_LATITUDE=12.9716
VITE_OFFICE_LONGITUDE=77.5946
VITE_GEOFENCE_RADIUS_METERS=200
